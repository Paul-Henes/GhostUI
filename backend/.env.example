# Ghost-UI Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# AI Services
# ===========================================
# OpenAI (for code fixes and UX analysis)
OPENAI_API_KEY=sk-your-openai-key

# Google Gemini (for vision-based accessibility scanning)
GEMINI_API_KEY=your-gemini-key

# ===========================================
# n8n Integration (optional)
# ===========================================
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxx

# ===========================================
# Application Settings
# ===========================================
DEBUG=false

# Public URL of this backend (used for embed snippets)
# In production, set this to your deployed API URL
BACKEND_PUBLIC_URL=http://localhost:8000

# ===========================================
# CORS Configuration
# ===========================================
# Additional allowed origins (comma-separated)
# Default origins (ghostui.xyz, www.ghostui.xyz, localhost) are always allowed
# Add Vercel preview URLs or other domains here
ALLOWED_ORIGINS=
