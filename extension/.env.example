# Ghost-UI Extension Environment Variables
# Copy to .env and fill in values

# Backend API URL for Voice Agent (required for Talk to Any Website)
PLASMO_PUBLIC_API_URL=https://ghost-ui-backend.replit.app

# ElevenLabs Widget script URL
PLASMO_PUBLIC_ELEVENLABS_WIDGET_URL=https://unpkg.com/@elevenlabs/convai-widget-embed
