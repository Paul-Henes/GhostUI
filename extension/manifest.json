{
  "manifest_version": 3,
  "name": "Ghost UI - AI Chatbot",
  "version": "1.1.0",
  "description": "AI-powered chatbot that understands webpage content using OpenAI",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "<all_urls>",
    "https://api.elevenlabs.io/*",
    "https://api.openai.com/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/webpage-extractor.js",
        "lib/openai-service.js",
        "lib/supabase-service.js",
        "content/chatbot.js"
      ],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
