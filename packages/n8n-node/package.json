{
  "name": "n8n-nodes-ghostui",
  "version": "0.2.0",
  "description": "n8n community node for Ghost-UI accessibility platform - WCAG scanning, compliance reports & AI fixes",
  "keywords": [
    "n8n-community-node-package",
    "accessibility",
    "wcag",
    "a11y",
    "compliance",
    "bfsg",
    "ghost-ui"
  ],
  "license": "MIT",
  "homepage": "https://ghostui.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasbxyz/ghostui.git",
    "directory": "packages/n8n-node"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GhostUiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GhostUI/GhostUI.node.js",
      "dist/nodes/GhostUI/GhostUITrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.22.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
